class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        int size=nums.size();
        
        for(int i=0;i<size;i++){
            for(int j=1+i;j<size;j++)
            {
                if(nums[j]==target-nums[i]){
                    return {i,j};
                }
            }
        }
        return {};
}
