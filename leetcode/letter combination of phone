from typing import List
class Solution:
    def letterCombinations(self, digits: str) -> List[str]:
        if not digits:
            return []
        d = ["abc", "def", "ghi", "jkl", "mno", "pqrs", "tuv", "wxyz"]
        ans = [""]
        for digit in digits:
            s = d[int(digit) - 2]
            new_ans = []
            for a in ans:
                for b in s:   
                    new_ans.append(a + b)
            ans = new_ans
            
        return ans
